/* ===== 往下是你原有的所有样式，原封不动 ===== */
page {
  background-color: #f0f2f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
}

/* ===== 顶部 ===== */
.header-section {
  background: #ffffff;
  padding: 25rpx 40rpx 10rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.logo-area { margin-bottom: 20rpx; }
.logo-text { font-size: 52rpx; font-weight: 900; margin: 0 4rpx; }
.blue { color: #4285F4; }
.green { color: #34A853; }
.red { color: #EA4335; }

/* ===== 搜索框 ===== */
.search-bar {
  background: #f1f3f4;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  width: 100%;
}
.search-input { flex: 1; margin-left: 15rpx; font-size: 28rpx; color: #202124; }

.clear-icon {
  padding: 10rpx;
  margin-right: -10rpx;
}

/* ===== 分类 ===== */
.category-scroll {
  white-space: nowrap; background: #fff; padding: 16rpx 0; border-bottom: 1rpx solid #eee;
}
.category-item {
  display: inline-block; padding: 10rpx 38rpx; font-size: 32rpx; color: #5f6368;
}
.category-item.active { color: #4285F4; font-weight: bold; position: relative; }
.category-item.active::after {
  content: ''; position: absolute; bottom: -12rpx; left: 35%;
  width: 30%; height: 6rpx; background: #4285F4; border-radius: 3rpx;
}

/* ===== 列表与卡片 ===== */
.post-list { padding: 30rpx 30rpx; }
.archive-card-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 25rpx 35rpx !important; margin-bottom: 25rpx; background: #fff;
}
.header-left { display: flex; align-items: center; flex: 1; overflow: hidden; }
.blue-line { width: 8rpx; height: 32rpx; background-color: #4285F4; border-radius: 4rpx; margin-right: 18rpx; flex-shrink: 0; }
.archive-label { font-size: 26rpx; color: #9aa0a6; white-space: nowrap; }
.archive-value {
  font-size: 28rpx; font-weight: bold; color: #202124; margin-left: 8rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 180rpx; 
}
.header-right { flex-shrink: 0; margin-left: 15rpx; }
.archive-count { font-size: 24rpx; color: #9aa0a6; }
.count-number { font-weight: bold; color: #4285F4; font-size: 30rpx; }

.post-card {
  background: #fff; border-radius: 32rpx; padding: 35rpx;
  margin-bottom: 25rpx; box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.04);
}
.post-title { font-size: 36rpx; font-weight: bold; color: #4285F4; margin-bottom: 18rpx; }
.post-info { display: flex; gap: 24rpx; margin-bottom: 20rpx; }
.info-inner { display: flex; align-items: center; }
.dot { width: 14rpx; height: 14rpx; border-radius: 50%; margin-right: 10rpx; }
.blue-dot { background: #4285F4; }
.green-dot { background: #34A853; }
.red-dot { background: #EA4335; }
.info-text { font-size: 24rpx; color: #9aa0a6; }
.post-desc {
  font-size: 28rpx; color: #5f6368; line-height: 1.6;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}

/* 分页 */
.pagination { display: flex; justify-content: center; align-items: center; gap: 30rpx; padding: 50rpx 0; }
.page-btn {
  background: #ffffff !important; color: #4285F4 !important;
  height: 80rpx !important; line-height: 80rpx !important;
  border-radius: 40rpx !important; border: 2rpx solid #4285F4 !important;
  font-size: 28rpx !important; font-weight: 500 !important; padding: 0 45rpx !important;
}
.page-btn[disabled] { color: #bdc1c6 !important; border-color: #eee !important; background: #fafafa !important; }
.page-info { font-size: 28rpx; color: #5f6368; white-space: nowrap; }

/* 悬浮按钮 */
.fab-btn {
  position: fixed; right: 40rpx; bottom: calc(50rpx + env(safe-area-inset-bottom));
  width: 110rpx; height: 110rpx; background-color: #4285F4; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(66, 133, 244, 0.4); z-index: 99;
}
.fab-icon { color: #ffffff; font-size: 60rpx; font-weight: 300; margin-top: -6rpx; }

.empty-box { margin-top: 120rpx; display: flex; flex-direction: column; align-items: center; color: #9aa0a6; }
.empty-img { width: 220rpx; height: 220rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 32rpx; font-weight: 600; }
.empty-sub { font-size: 24rpx; color: #bdc1c6; }

/* === 5. 优雅加载态样式 === */
.loading-full-screen {
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  /* ⭐ 严格对齐你卡片的背景色：纯白 */
  background-color: #ffffff; 
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: fadeIn 0.8s ease;
}

.loading-logo {
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 40rpx;
  /* 既然是纯白背景，Logo 稍微清晰一点 */
  opacity: 0.9; 
  animation: breathe 2s infinite ease-in-out;
}

.loading-bar {
  width: 240rpx;
  height: 4rpx;
  /* ⭐ 使用你搜索框的背景色 #f1f3f4，视觉上更统一 */
  background-color: #f1f3f4; 
  border-radius: 4rpx;
  overflow: hidden;
  position: relative;
}

.loading-line {
  width: 100rpx;
  height: 100%;
  /* ⭐ 蓝色使用你主题里的 Google 蓝 #4285F4 */
  background: linear-gradient(90deg, transparent, #4285F4, transparent);
  position: absolute;
  left: -100rpx;
  animation: flow 1.5s infinite linear;
}

.loading-hint {
  font-size: 24rpx;
  /* 使用你 post-info 里的文字颜色 #9aa0a6 */
  color: #9aa0a6; 
  margin-top: 24rpx;
  letter-spacing: 2rpx;
}

/* --- 动画定义 --- */
@keyframes breathe {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.05); opacity: 0.85; }
}

@keyframes flow {
  0% { left: -100rpx; }
  100% { left: 240rpx; }
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}
/* 修改原有的 .header-section 内部布局 */
.logo-wrapper {
  width: 100%;
  display: flex;
  justify-content: center; /* Logo 居中 */
  align-items: center;
  position: relative;
  margin-bottom: 20rpx;
}

.message-entry {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 10rpx;
}

.message-icon {
  width: 52rpx;
  height: 52rpx;
}

/* 未读数红点 */
.badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  background-color: #EA4335;
  color: #fff;
  font-size: 20rpx;
  min-width: 30rpx;
  height: 30rpx;
  border-radius: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 4rpx;
  border: 2rpx solid #fff;
  font-weight: bold;
}

/* 下拉加载样式 */
.load-more-status {
  text-align: center;
  padding: 40rpx 0 60rpx;
}

.loading-inline {
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 26rpx;
  color: #9aa0a6;
}

.no-more {
  font-size: 24rpx;
  color: #bdc1c6;
}

/* 简单的跳动点动画 */
.dot-jump {
  width: 8rpx; height: 8rpx; background: #4285F4;
  border-radius: 50%; margin-right: 15rpx;
  animation: jump 0.6s infinite alternate;
}
@keyframes jump { from { transform: translateY(0); } to { transform: translateY(-10rpx); } }