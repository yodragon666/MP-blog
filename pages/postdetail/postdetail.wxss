page {
  background: #ffffff;
  padding-bottom: 140rpx;
}

.page { padding: 40rpx 30rpx; }

/* 首页蓝标题 */
.post-title-blue {
  font-size: 52rpx;
  font-weight: 900;
  color: #4285F4;
  line-height: 1.3;
  margin-bottom: 30rpx;
}

/* 不明显的分界线 */
.divider-line {
  height: 1rpx;
  background: #f1f3f4;
  margin: 40rpx 0;
}

/* 放大后的乳白卡片 */
.author-card-pro {
  display: flex;
  align-items: center;
  background: #f8f9fa; /* 乳白色/浅灰色背景 */
  padding: 40rpx 30rpx; /* 增大内边距 */
  border-radius: 24rpx;
  margin-bottom: 40rpx;
}

.avatar-large {
  width: 110rpx; /* 头像加大 */
  height: 110rpx;
  border-radius: 50%;
  margin-right: 25rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.author-info { flex: 1; }
.nickname { font-size: 34rpx; font-weight: bold; color: #202124; margin-bottom: 10rpx; }
.author-meta { 
  font-size: 24rpx; color: #70757a; 
  display: flex; flex-wrap: wrap; gap: 12rpx; 
}

/* 标签 & 描述（保持原样） */
.tags { display: flex; flex-wrap: wrap; gap: 14rpx; margin-bottom: 30rpx; }
.tag { background: #f1f3f4; color: #4285F4; padding: 8rpx 22rpx; border-radius: 40rpx; font-size: 22rpx; }
.desc {
  font-size: 28rpx; color: #5f6368; line-height: 1.8;
  margin-bottom: 40rpx; padding-left: 20rpx;
  border-left: 6rpx solid #4285F4;
}

/* 正文 */
.content { font-size: 34rpx; color: #3c4043; line-height: 1.8; margin-bottom: 60rpx; }

/* 极简翻页 */
.simple-nav {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
}
.nav-link {
  flex: 1;
  font-size: 26rpx;
  color: #4285F4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.text-right { text-align: right; }
.nav-link.disabled { color: #bdc1c6; }
.arrow { font-weight: bold; }

/* 底部工具栏 - 严格对齐 */
.toolbar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  height: 110rpx;
  background: #ffffff;
  border-top: 1rpx solid #eee;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 1000;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.03);
}

.toolbar-left { font-size: 28rpx; color: #5f6368; }
.home-link { color: #4285F4; font-weight: bold; margin: 0 6rpx; }

.toolbar-right {
  display: flex;
  align-items: center;
  gap: 45rpx; /* 间距一致 */
}

.icon { width: 50rpx; height: 50rpx; display: block; }

/* 覆盖按钮默认样式 */
.share-btn {
  background: transparent !important;
  padding: 0 !important;
  margin: 0 !important;
  width: 50rpx !important;
  line-height: normal !important;
}
.share-btn::after { border: none; }

/* 点赞/收藏 变红逻辑 (不需要换图片，直接滤镜变红) */
.active-red .icon {
  filter: drop-shadow(1000px 0 0 #EA4335);
  transform: translateX(-1000px);
}