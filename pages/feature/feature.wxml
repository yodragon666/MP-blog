<view wx:if="{{isReady}}" class="page-container">

<view class="header-section">
  <view class="logo-area">
    <text class="logo-text blue">轻</text>
    <text class="logo-text green">博</text>
    <text class="logo-text red">客</text>
  </view>
</view>

<view class="post-list">
  <block wx:if="{{!hasSearched}}">
    <view class="card">
      <view class="card-title">专题标签</view>
      <view class="tag-grid">
        <view class="tag-item {{item.active ? 'active' : ''}}" 
              wx:for="{{tagList}}" 
              wx:key="id" 
              bindtap="toggleTag" 
              data-id="{{item.id}}">
          {{item.name}}
        </view>
      </view>
    </view>

    <view class="card" wx:if="{{selectedTags.length > 0}}">
      <view class="clear-all" bindtap="clearAllTags">
        <icon type="clear" size="14" color="#9aa0a6"></icon>
        <text class="clear-all-text">清空</text>
      </view>

      <view class="card-title" style="border-left-color: #34A853;">已选标签</view>
      
      <view class="selected-tags-wrap">
        <view class="selected-tag" 
          wx:for="{{selectedTagsList}}" 
          wx:key="id" 
          bindtap="removeTag" 
          data-id="{{item.id}}">
        {{item.name}} <text class="tag-close">✕</text>
      </view>
    </view>
      
      <button class="confirm-btn" bindtap="confirmSearch">
        查看相关文章({{previewCount}})
      </button>
    </view>

    <view class="empty-box" wx:else style="margin-top: 60rpx;">
      <view class="empty-text">请在上方选择标签</view>
      <view class="empty-sub">支持多个标签组合筛选</view>
    </view>
    <view wx:if="{{isReviewed}}" class="fab-btn" bindtap="goToAddPost">
      <text class="fab-icon">+</text>
    </view>
  </block>

  <block wx:else>
    <view class="post-card archive-card-header">
      <view class="header-left">
        <view class="blue-line"></view>
        <text class="archive-label">筛选结果：共 <text class="bold-count">{{total}}</text> 篇</text>
      </view>
      <view class="header-right" bindtap="resetSearch">
        <text class="re-select">重新选择</text>
      </view>
    </view>

    <block wx:if="{{postList.length > 0}}">
      <view class="post-card" 
            wx:for="{{postList}}" 
            wx:key="id" 
            bindtap="goToDetail" 
            data-id="{{item.id}}">
        <view class="post-title">{{item.title}}</view>
        <view class="post-info">
          <view class="info-inner"><view class="dot blue-dot"></view><text class="info-text">{{item.author}}</text></view>
          <view class="info-inner"><view class="dot green-dot"></view><text class="info-text">{{item.add_date}}</text></view>
          <view class="info-inner"><view class="dot red-dot"></view><text class="info-text">{{item.pv}} 阅读</text></view>
        </view>
        <view class="post-desc">{{item.desc}}</view>
      </view>

      <view class="pagination">
        <button class="page-btn" bindtap="prevPage" disabled="{{page <= 1}}">上一页</button>
        <text class="page-info">{{page}} / {{totalPage}}</text>
        <button class="page-btn" bindtap="nextPage" disabled="{{page >= totalPage}}">下一页</button>
      </view>
    </block>

    <block wx:else>
      <view class="empty-box">
        <image src="/assets/icons/nothings.png" class="empty-img" mode="aspectFit"/>
        <view class="empty-text">未找到匹配文章</view>
        <button class="page-btn adjust-btn" bindtap="resetSearch">调整标签组合</button>
      </view>
    </block>
  </block>
</view>
</view>

<view wx:else class="loading-full-screen">
<view class="loading-content">
  <view class="loading-bar"><view class="loading-line"></view></view>
  <text class="loading-hint">正在加载中</text>
</view>
</view>