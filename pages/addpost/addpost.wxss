page { background-color: #f0f2f5; font-family: -apple-system, sans-serif; }
.header-section { background: #fff; padding: 25rpx 0; display: flex; justify-content: center; }
.logo-text { font-size: 52rpx; font-weight: 900; margin: 0 4rpx; }
.blue { color: #4285F4; } .green { color: #34A853; } .red { color: #EA4335; }

.post-list { padding: 30rpx; }
.card { background: #fff; border-radius: 32rpx; padding: 35rpx; margin-bottom: 25rpx; }
.card-title { font-size: 34rpx; font-weight: 700; color: #202124; border-left: 8rpx solid #4285F4; padding-left: 20rpx; margin-bottom: 30rpx; }

.input-box, .textarea-box {
  background: #f8f9fa;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #202124;
  width: 100%;
  box-sizing: border-box;
}

.input-box { height: 90rpx; padding: 0 30rpx; }
.textarea-box { padding: 30rpx !important; line-height: 1.6; }
.desc-box { height: 160rpx; }

.content-wrapper { background: #f8f9fa; border-radius: 16rpx; position: relative; padding-bottom: 140rpx; }
.content-box { background: transparent !important; }

.add-img-btn {
  position: absolute; right: 30rpx; bottom: 30rpx; width: 110rpx; height: 110rpx;
  border: 4rpx solid #dadce0; color: #9aa0a6; display: flex; align-items: center;
  justify-content: center; font-size: 70rpx; font-weight: 300; border-radius: 16rpx;
  z-index: 10; background: #f8f9fa;
}

.inner-image-preview { display: flex; flex-wrap: wrap; padding: 0 20rpx 20rpx; gap: 15rpx; }
.preview-item { width: 140rpx; height: 140rpx; position: relative; }
.preview-img { width: 100%; height: 100%; border-radius: 12rpx; }
.delete-btn {
  position: absolute; top: -10rpx; right: -10rpx; width: 36rpx; height: 36rpx;
  background: rgba(0,0,0,0.4); color: #fff; border-radius: 50%;
  text-align: center; line-height: 32rpx; font-size: 24rpx;
}

.picker-selector { background: #f8f9fa; height: 90rpx; line-height: 90rpx; padding: 0 30rpx; border-radius: 16rpx; display: flex; justify-content: space-between; align-items: center; color: #9aa0a6; font-size: 30rpx; }
.picker-selector.selected { color: #202124; }
.arrow-down { font-size: 24rpx; color: #bdc1c6; }

.tag-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.tag-item { padding: 12rpx 28rpx; background: #f1f3f4; border-radius: 40rpx; font-size: 26rpx; color: #5f6368; }
.tag-item.active-blue { background: #e8f0fe !important; color: #4285F4 !important; }

/* 底部按钮组 */
.button-group { display: flex; gap: 20rpx; margin-top: 40rpx; padding-bottom: 50rpx; }
.draft-btn, .confirm-btn {
  height: 96rpx !important; border-radius: 48rpx !important; font-size: 30rpx;
  font-weight: bold; display: flex !important; align-items: center; justify-content: center;
  padding: 0 !important; margin: 0 !important;
}
.draft-btn { flex: 1; background: #e8eaed !important; color: #5f6368 !important; }
.confirm-btn { flex: 2; background: #4285F4 !important; color: #fff !important; }