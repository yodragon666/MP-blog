<view class="container">
  <view class="title">填写基本信息</view>

  <view class="form-group">
    <view class="input-item">
      <input type="text" placeholder="请输入用户名" model:value="{{username}}" />
    </view>
    
    <view class="input-item">
      <input type="text" placeholder="请输入邮箱" model:value="{{email}}" />
    </view>

    <view class="input-item password-wrap">
      <input 
        password="{{!isPasswordVisible1}}" 
        placeholder="请输入密码" 
        model:value="{{password}}" 
        class="password-input"
      />
      <view class="eye-btn" bindtap="togglePasswordVisible1">
        <image 
          src="{{isPasswordVisible1 ? '/assets/icons/eye-open.png' : '/assets/icons/eye-close.png'}}" 
          mode="aspectFit" 
          style="width: 40rpx; height: 40rpx;"
        />
      </view>
    </view>

    <view class="input-item password-wrap">
      <input 
        password="{{!isPasswordVisible2}}" 
        placeholder="请再次输入密码" 
        model:value="{{password1}}" 
        class="password-input"
      />
      <view class="eye-btn" bindtap="togglePasswordVisible2">
        <image 
          src="{{isPasswordVisible2 ? '/assets/icons/eye-open.png' : '/assets/icons/eye-close.png'}}" 
          mode="aspectFit" 
          style="width: 40rpx; height: 40rpx;"
        />
      </view>
    </view>
  </view>

  <button class="btn-submit" bindtap="handleNext">下一步</button>
</view>