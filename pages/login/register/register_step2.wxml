<view class="container">
  <view class="title">邮箱验证</view>

  <view class="form-group">
    <view class="input-item read-only-row">
      <text class="label">邮箱</text>
      <text class="value">{{email}}</text>
    </view>

    <view class="input-item code-wrap">
      <input type="number" placeholder="请输入验证码" model:value="{{code}}" maxlength="6" />
      <button class="btn-code" disabled="{{countdown > 0}}" bindtap="sendCode">
        {{countdown > 0 ? countdown + 's' : '获取验证码'}}
      </button>
    </view>
  </view>

  <button class="btn-submit" bindtap="handleFinalRegister">立即注册</button>
</view>