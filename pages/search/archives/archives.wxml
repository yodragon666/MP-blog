<view class="page-container">
  <view class="header">
    <text class="logo blue">轻</text>
    <text class="logo green">博</text>
    <text class="logo red">客</text>
  </view>

  <view class="post-list">
    
    <view class="post-card archive-card-header">
      <view class="header-left">
        <view class="blue-line"></view>
        <text class="archive-label">每月归档：</text>
        <text class="archive-value">{{year}}年{{month}}月</text>
      </view>
      <view class="header-right">
        <text class="archive-count">共 {{total || 0}} 篇</text>
      </view>
    </view>

    <block wx:if="{{postList.length > 0}}">
      <view class="post-card" wx:for="{{postList}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
        <view class="post-title">{{item.title}}</view>
        <view class="post-info">
          <view class="info-inner"><view class="dot blue-dot"></view><text class="info-text">{{item.author}}</text></view>
          <view class="info-inner"><view class="dot green-dot"></view><text class="info-text">{{item.publish_time}}</text></view>
          <view class="info-inner"><view class="dot red-dot"></view><text class="info-text">{{item.pv}} 阅读</text></view>
        </view>
        <view class="post-desc">{{item.desc}}</view>
      </view>
      
      <view class="pagination">
        <button class="page-btn" bindtap="prevPage" disabled="{{page <= 1}}">上一页</button>
        <text class="page-info">{{page}} / {{totalPage}}</text> 
        <button class="page-btn" bindtap="nextPage" disabled="{{page >= totalPage}}">下一页</button>
      </view>
    </block>

    <block wx:else>
      <view class="empty-box">
        <image src="/assets/icons/nothings.png" class="empty-img" mode="aspectFit"/>
        <view class="empty-text">暂无归档内容</view>
      </view>
    </block>

  </view> 
</view>