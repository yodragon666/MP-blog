page {
  background-color: #f7f8fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
}

.container {
  padding: 0 30rpx; /* 统一侧边留白 */
  box-sizing: border-box;
}

/* ⭐ 同步居中标题样式 */
.title {
  font-size: 40rpx;         /* 统一字号 */
  font-weight: 600;         /* 统一字重 */
  color: #333;
  text-align: center;       /* 居中 */
  display: block;
  margin: 40rpx auto 40rpx auto; /* 顶部 25rpx，底部 30rpx，锁定间距 */
  width: 100%;
}

.menu-list {
  background-color: #ffffff;
  border-radius: 28rpx;    /* 统一圆角 */
  padding: 0 32rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.03); /* 统一微阴影 */
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon-small {
  width: 44rpx; /* 稍微放大一点点，视觉上更饱满 */
  height: 44rpx;
  margin-right: 24rpx;
}

.menu-title {
  font-size: 30rpx;
  color: #333;
}

.menu-right {
  display: flex;
  align-items: center;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
  font-family: consolas;
}

.tips {
  font-size: 24rpx;
  color: #999;
  padding: 30rpx 20rpx;
  line-height: 1.6;
}

/* 增加点击态 */
.menu-item:active {
  background-color: #fafafa;
}
