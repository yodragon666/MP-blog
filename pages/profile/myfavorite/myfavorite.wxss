page { background-color: #f0f2f5; }

/* 顶部设计 */
.header-section {
  background: #ffffff; padding: 40rpx 30rpx;
  display: flex; flex-direction: column; align-items: center;
}
.big-status-title { font-size: 44rpx; font-weight: 800; color: #202124; }
.sub-header-line { width: 40rpx; height: 6rpx; background: #4285F4; margin-top: 16rpx; border-radius: 3rpx; }

/* 位置指示器 */
.post-list { padding: 30rpx; }
.archive-card-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 25rpx 35rpx !important; margin-bottom: 25rpx; background: #fff; border-radius: 28rpx;
}
.header-left { display: flex; align-items: center; }
.blue-line { width: 8rpx; height: 32rpx; background-color: #4285F4; border-radius: 4rpx; margin-right: 18rpx; }
.archive-label { font-size: 26rpx; color: #9aa0a6; }
.archive-value { font-size: 28rpx; font-weight: bold; color: #4285F4; margin-left: 8rpx; }
.count-number { font-weight: bold; color: #4285F4; font-size: 32rpx; }

/* 文章卡片 */
.post-card {
  background: #fff; border-radius: 32rpx; padding: 35rpx;
  margin-bottom: 25rpx; box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.04);
}
.post-title { font-size: 36rpx; font-weight: bold; color: #202124; margin-bottom: 18rpx; }
.post-info { display: flex; gap: 24rpx; margin-bottom: 20rpx; }
.info-inner { display: flex; align-items: center; }
.dot { width: 14rpx; height: 14rpx; border-radius: 50%; margin-right: 10rpx; }
.blue-dot { background: #4285F4; }
.green-dot { background: #34A853; }
.red-dot { background: #EA4335; }
.info-text { font-size: 24rpx; color: #9aa0a6; }
.post-desc {
  font-size: 28rpx; color: #5f6368; line-height: 1.6;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}

/* 加载动画 */
.load-more-status { text-align: center; padding: 40rpx 0; }
.loading-inline { display: flex; justify-content: center; align-items: center; font-size: 26rpx; color: #9aa0a6; }
.dot-jump {
  width: 8rpx; height: 8rpx; background: #4285F4; border-radius: 50%; margin-right: 15rpx;
  animation: jump 0.6s infinite alternate;
}
@keyframes jump { from { transform: translateY(0); } to { transform: translateY(-10rpx); } }
.no-more { font-size: 24rpx; color: #bdc1c6; }

/* 修正后的空状态样式 */
.empty-box { 
  margin-top: 150rpx; 
  display: flex; 
  flex-direction: column; 
  align-items: center; 
  justify-content: center;
}
.empty-img { 
  width: 180rpx; 
  height: 180rpx; 
  margin-bottom: 20rpx; 
  opacity: 0.5; /* 保持与第一个模板一致的通透感 */
}
.empty-text { 
  font-size: 28rpx; 
  color: #bdc1c6; 
}

/* 全屏加载 */
.loading-full-screen {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background: #fff; display: flex; justify-content: center; align-items: center; z-index: 999;
}
.loading-content { display: flex; flex-direction: column; align-items: center; }
.loading-bar { width: 200rpx; height: 4rpx; background: #f0f2f5; border-radius: 2rpx; overflow: hidden; margin-bottom: 20rpx; }
.loading-line { width: 60rpx; height: 100%; background: #4285F4; animation: loading 1s infinite linear; }
@keyframes loading { from { transform: translateX(-60rpx); } to { transform: translateX(200rpx); } }
.loading-hint { font-size: 24rpx; color: #9aa0a6; }