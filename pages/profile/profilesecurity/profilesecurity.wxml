<view class="container">
  <view class="title">账号安全</view>

  <view class="menu-list">
    <view class="menu-item" bindtap="goToChangeAccount">
      <view class="menu-left">
        <text class="menu-title">修改账号</text>
      </view>
      <view class="menu-right">
        <text class="current-value">{{displayUserInfo.username || '未绑定'}}</text>
        <text class="menu-arrow">></text>
      </view>
    </view>

    <view class="menu-item" bindtap="goToChangeEmail">
      <view class="menu-left">
        <text class="menu-title">修改邮箱</text>
      </view>
      <view class="menu-right">
        <text class="current-value">{{displayUserInfo.email || '未绑定'}}</text>
        <text class="menu-arrow">></text>
      </view>
    </view>

    <view class="menu-item" bindtap="goToChangePassword">
      <view class="menu-left">
        <text class="menu-title">修改登录密码</text>
      </view>
      <view class="menu-right">
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <view class="menu-list" style="margin-top: 30rpx;" wx:if="{{ is_guest && !is_completed }}">
    <view class="menu-item" bindtap="goToCompleteProfile">
      <view class="menu-left">
        <text class="menu-title" >补全信息</text>
      </view>
      <view class="menu-right">
        <text class="current-value" style="color: #fa5151;">去补全</text>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <view class="menu-list" style="margin-top: 30rpx;">
    <view wx:if="{{ !is_guest && !is_completed }}" class="menu-item" bindtap="handleBindWechat">
      <view class="menu-left">
        <text class="menu-title">绑定微信</text>
      </view>
      <view class="menu-right">
        <text class="current-value" style="color: #fa5151;">去绑定</text>
        <text class="menu-arrow">></text>
      </view>
    </view>

    <view wx:else class="menu-item" bindtap="handleUnbindWechat">
      <view class="menu-left">
        <text class="menu-title">解绑微信</text>
      </view>
      <view class="menu-right">
        <text class="current-value">已绑定</text>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <view class="danger-zone">
    <view class="menu-list" style="margin-top: 30rpx;">
      <view class="menu-item" bindtap="handleDeleteAccount">
        <view class="menu-left">
          <text class="menu-title danger-text">注销账号</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
    </view>
    <view class="tips">注销后，账号数据将被永久删除。</view>
  </view>
</view>