<view class="container">
  <view class="title">补全用户信息</view>

  <view class="form-group">
    <view class="input-item">
      <input 
        type="number" 
        placeholder="请输入手机号" 
        value="{{username}}"
        maxlength="11"
        bindinput="onUsernameInput"
      />
    </view>

    <view class="input-item email-group">
      <input 
        type="text" 
        placeholder="请输入邮箱地址" 
        value="{{email}}"
        bindinput="onEmailInput"
      />
      <view class="verify-code-btn {{isCounting ? 'disabled' : ''}}" bindtap="sendCode">
        {{isCounting ? count + 's后重送' : '获取验证码'}}
      </view>
    </view>

    <view class="input-item">
      <input 
        type="number" 
        placeholder="请输入邮箱验证码" 
        value="{{code}}"
        maxlength="6"
        bindinput="onCodeInput"
      />
    </view>

    <view class="input-item password-wrap">
      <input 
        password="{{!isPwdVisible1}}" 
        placeholder="请设置登录密码 (至少6位)" 
        value="{{password}}"
        bindinput="onPasswordInput"
        class="password-input"
      />
      <view class="eye-btn" bindtap="togglePwdVisible1">
        <image src="{{isPwdVisible1 ? '/assets/icons/eye-open.png' : '/assets/icons/eye-close.png'}}" mode="aspectFit" style="width: 40rpx; height: 40rpx;" />
      </view>
    </view>

    <view class="input-item password-wrap">
      <input 
        password="{{!isPwdVisible2}}" 
        placeholder="请再次输入密码" 
        value="{{password1}}"
        bindinput="onPassword1Input"
        class="password-input"
      />
      <view class="eye-btn" bindtap="togglePwdVisible2">
        <image src="{{isPwdVisible2 ? '/assets/icons/eye-open.png' : '/assets/icons/eye-close.png'}}" mode="aspectFit" style="width: 40rpx; height: 40rpx;" />
      </view>
    </view>
  </view>

  <button class="btn-submit" bindtap="handleComplete">提交</button>

  <view class="link-group">
    <text></text>
    <text class="link register-link" bindtap="goToBindAccount">已有账户？立即绑定</text>
  </view>
</view>