<!--pages/profile/changeemail/changeemail_step2.wxml-->
<view class="container">
  <view class="title">绑定新邮箱</view>

  <view class="form-group">
    <view class="input-item">
      <input 
        class="value"
        type="text" 
        placeholder="请输入新邮箱地址" 
        value="{{newemail}}" 
        bindinput="onNewEmailInput"
      />
    </view>

    <view class="input-item code-wrap">
      <input 
        type="number" 
        placeholder="请输入验证码" 
        value="{{newcode}}" 
        bindinput="onNewCodeInput"
        maxlength="6" 
      />
      <button class="btn-code" disabled="{{countdown > 0}}" bindtap="sendNewCode">
        {{countdown > 0 ? countdown + 's后重发' : '获取验证码'}}
      </button>
    </view>
  </view>

  <button class="btn-submit" bindtap="handleSubmit">确认修改</button>
</view>