<view class="container">
  <view class="title">修改密码</view>

  <view class="form-group">
    <view class="input-item read-only-row">
      <text class="label">邮箱</text>
      <text class="value">{{email}}</text>
    </view>

    <view class="input-item code-wrap">
      <input type="number" placeholder="请输入验证码" value="{{code}}" bindinput="onCodeInput" maxlength="6" />
      <button class="btn-code" disabled="{{countdown > 0}}" bindtap="sendCode">
        {{countdown > 0 ? countdown + 's后重发' : '获取验证码'}}
      </button>
    </view>

    <view class="input-item password-wrap">
      <input password="{{!isPwdVisible1}}" placeholder="请输入新密码" value="{{newpwd}}" bindinput="onNewPwdInput" class="password-input" />
      <view class="eye-btn" bindtap="togglePwdVisible1">
        <image src="{{isPwdVisible1 ? '/assets/icons/eye-open.png' : '/assets/icons/eye-close.png'}}" mode="aspectFit" style="width: 40rpx; height: 40rpx;" />
      </view>
    </view>

    <view class="input-item password-wrap">
      <input password="{{!isPwdVisible2}}" placeholder="请再次输入新密码" value="{{confirmpwd}}" bindinput="onConfirmPwdInput" class="password-input" />
      <view class="eye-btn" bindtap="togglePwdVisible2">
        <image src="{{isPwdVisible2 ? '/assets/icons/eye-open.png' : '/assets/icons/eye-close.png'}}" mode="aspectFit" style="width: 40rpx; height: 40rpx;" />
      </view>
    </view>
  </view> <button class="btn-submit" bindtap="handleSubmit">确认修改</button>
</view>