.container { 
  padding: 60rpx; 
  background-color: #ffffff;
  min-height: 100vh;
  box-sizing: border-box;
}

.title { 
  font-size: 48rpx; 
  font-weight: bold; 
  margin-bottom: 80rpx; 
  color: #333; 
  text-align: center; 
}

/* 统一输入行样式 */
.input-item { 
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #f2f2f2; 
  padding: 30rpx 0; 
}

/* 1. 邮箱只读行优化 */
.read-only-row .label {
  font-size: 32rpx;
  color: #333; /* 标签用深色 */
  width: 120rpx; /* 固定宽度，让后面的内容对齐 */
}

.read-only-row .value {
  font-size: 32rpx;
  color: #999; /* 邮箱用灰色，表示不可修改 */
  flex: 1;
}

/* 2. 验证码行优化 */
.code-wrap input {
  flex: 1;
  font-size: 32rpx;
}

/* 获取验证码按钮风格 */
.btn-code {
  background: transparent !important;
  color: #576b95 !important;
  font-size: 28rpx !important;
  width: auto !important;
  padding: 0 10rpx !important;
  margin: 0 !important;
  font-weight: 500;
  border: none !important;
  line-height: 1.5; /* 调整行高避免被切断 */
}

.btn-code::after {
  border: none;
}

.btn-code[disabled] {
  color: #ccc !important;
}

/* 立即注销按钮 */
.btn-submit { 
  width: 100% !important; 
  background: #f2f2f2 !important; 
  color: #fa5151 !important; /* 注销建议用红色，或者维持 #333 */
  border-radius: 12rpx; 
  margin-top: 80rpx; 
  height: 96rpx; 
  font-weight: 600;
  font-size: 32rpx;
  display: flex; 
  align-items: center; 
  justify-content: center;
}

.btn-submit:active {
  background-color: #e5e5e5 !important;
}