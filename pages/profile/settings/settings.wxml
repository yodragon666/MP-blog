<view class="container">
  <view class="title">系统设置</view>

  <view class="menu-list">
    <view class="menu-item" bindtap="handleClearCache">
      <view class="menu-left">
        <text class="menu-title">清理缓存</text>
      </view>
      <view class="menu-right">
        <text class="menu-arrow">></text>
      </view>
    </view>

    <view class="menu-item" bindtap="handleContactAdmin">
      <view class="menu-left">
        <text class="menu-title">联系管理员</text>
      </view>
      <view class="menu-right">
        <text class="menu-arrow">></text>
      </view>
    </view>

    <view class="menu-item" bindtap="goToLegal" data-type="agreement">
      <view class="menu-left">
        <text class="menu-title">用户协议</text>
      </view>
      <view class="menu-right">
        <text class="menu-arrow">></text>
      </view>
    </view>

    <view class="menu-item" bindtap="goToLegal" data-type="privacy">
      <view class="menu-left">
        <text class="menu-title">隐私政策</text>
      </view>
      <view class="menu-right">
        <text class="menu-arrow">></text>
      </view>
    </view>

    <view class="menu-item" bindtap="checkUpdate">
      <view class="menu-left">
        <text class="menu-title">关于系统</text>
      </view>
      <view class="menu-right">
        <text class="current-value">v1.0.0</text>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <view class="tips">© 2026 轻博客 · Built with Yodragon</view>
</view>